generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Startup {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  tagline     String
  description String?
  logo        String?
  website     String
  twitter     String?
  linkedin    String?
  category    String
  stage       String    @default("Pre-seed") // Pre-seed, Seed, Series A, Series B, Growth
  teamSize    String    @default("1-5")      // 1-5, 6-20, 21-50, 51-200, 200+
  foundedYear Int?
  country     String?
  email       String?
  upvotes     Int       @default(0)
  featured    Boolean   @default(false)
  launchTier      String    @default("free") // free, premium, premium-plus, seo-growth
  founderName     String?
  founderRole     String?
  founderLinkedin String?
  badgeVerified    Boolean   @default(false)
  badgeVerifiedAt  DateTime?
  launchDate       DateTime?
  status      String    @default("active") // active, acquired, paused
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  votes  Vote[]
  perks  Perk[]
  claimEmail ClaimEmail?
}

model Vote {
  id        String   @id @default(cuid())
  startupId String
  sessionId String
  createdAt DateTime @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([startupId, sessionId])
}

model Perk {
  id          String   @id @default(cuid())
  startupId   String
  title       String
  description String
  discount    String?
  url         String
  createdAt   DateTime @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id               String   @id @default(cuid())
  email            String   @unique
  unsubscribeToken String   @unique
  createdAt        DateTime @default(now())
}

model SponsorSlot {
  id          String   @id @default(cuid())
  companyName String
  logo        String?
  website     String
  tagline     String?
  plan        String   @default("1month") // 1month, 3months, 12months
  status      String   @default("active") // active, expired, paused
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  banners Banner[]
}

model Banner {
  id           String   @id @default(cuid())
  sponsorId    String?  // optional link to sponsor
  headline     String
  description  String?
  ctaText      String   @default("Learn More")
  ctaUrl       String
  imageUrl     String?  // background or hero image
  logoUrl      String?  // sponsor logo
  position     Int      @default(4) // after Nth startup card
  status       String   @default("active") // active, paused, expired
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  startsAt     DateTime @default(now())
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sponsor SponsorSlot? @relation(fields: [sponsorId], references: [id], onDelete: SetNull)
}

model ClaimEmail {
  id           String    @id @default(cuid())
  startupId    String    @unique
  token        String    @unique
  email        String
  status       String    @default("pending") // pending, sent, delivered, bounced, opened, clicked, claimed, failed
  resendId     String?
  sentAt       DateTime?
  deliveredAt  DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  claimedAt    DateTime?
  bouncedAt    DateTime?
  bounceReason String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id               String    @id @default(cuid())
  name             String
  key              String    @unique
  rateLimit        Int       @default(1000) // requests per hour
  tier             String    @default("free") // free, pro, enterprise
  monthlyRateLimit Int       @default(1000) // overrides per-tier defaults
  callsCount       Int       @default(0)
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // user, admin
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model CommunityBoard {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String
  icon        String                                        // emoji string
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  posts CommunityPost[]
}

model CommunityPost {
  id          String   @id @default(cuid())
  boardId     String
  title       String
  description String
  author      String
  startupName String?
  tags        String[]
  mrr         Int?                                          // in cents
  upvotes     Int      @default(0)
  sessionId   String?                                        // for voting dedup
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  board CommunityBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, createdAt])
}

model JobListing {
  id          String    @id @default(cuid())
  title       String
  company     String
  logo        String?
  website     String?
  location    String?                                      // nullable = remote
  type        String    @default("full-time")              // full-time, part-time, contract, internship
  salaryMin   Int?
  salaryMax   Int?
  currency    String    @default("USD")
  description String
  tags        String[]
  category    String    @default("Engineering")            // Engineering, Design, Product, Marketing, Sales, Operations, Finance, Customer Success
  isFeatured  Boolean   @default(false)
  isPaid      Boolean   @default(false)
  status      String    @default("active")                 // active, closed, expired
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DigestSponsor {
  id          String   @id @default(cuid())
  companyName String
  logo        String?
  website     String
  tagline     String?
  impressions Int      @default(0)
  clicks      Int      @default(0)
  status      String   @default("active") // active, paused, expired
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvestorProfile {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  company   String?
  website   String?
  focus     String[]
  stages    String[]
  checkSize String?
  bio       String?
  status    String   @default("active") // active, paused
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String?
  email            String
  plan             String    // "pro", "enterprise"
  status           String    @default("active") // active, cancelled, expired, past_due
  lemonSqueezyId   String?   @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
