generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Startup {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  tagline     String
  description String?
  logo        String?
  website     String
  twitter     String?
  linkedin    String?
  category    String
  stage       String    @default("Pre-seed") // Pre-seed, Seed, Series A, Series B, Growth
  teamSize    String    @default("1-5")      // 1-5, 6-20, 21-50, 51-200, 200+
  foundedYear Int?
  country     String?
  email       String?
  upvotes     Int       @default(0)
  featured    Boolean   @default(false)
  launchTier      String    @default("free") // free, premium, premium-plus, seo-growth
  badgeVerified    Boolean   @default(false)
  badgeVerifiedAt  DateTime?
  launchDate       DateTime?
  status      String    @default("active") // active, acquired, paused
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  votes  Vote[]
  perks  Perk[]
}

model Vote {
  id        String   @id @default(cuid())
  startupId String
  sessionId String
  createdAt DateTime @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)

  @@unique([startupId, sessionId])
}

model Perk {
  id          String   @id @default(cuid())
  startupId   String
  title       String
  description String
  discount    String?
  url         String
  createdAt   DateTime @default(now())

  startup Startup @relation(fields: [startupId], references: [id], onDelete: Cascade)
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model SponsorSlot {
  id          String   @id @default(cuid())
  companyName String
  logo        String?
  website     String
  tagline     String?
  plan        String   @default("1month") // 1month, 3months, 12months
  status      String   @default("active") // active, expired, paused
  startsAt    DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
